# ============================================================
# MasterOps AI — Development Environment Variables
#
# For LOCAL development:
#   Copy this file to .env.local and fill in the values.
#   .env.local is gitignored and will never be committed.
#
# For CLOUD development (GitHub Codespaces):
#   Do NOT create .env.local in a Codespace.
#   Set secrets in:
#   GitHub → Repository → Settings → Secrets and variables
#   → Codespaces → New repository secret
#   They are injected automatically on Codespace startup.
#
# ⚠ REQUIRED vs OPTIONAL:
#   The three Supabase variables are REQUIRED.
#   The app will crash on startup without them — the
#   Supabase client uses non-null assertions on these values.
#   All other variables are optional and fail gracefully.
# ============================================================


# ============================================================
# REQUIRED — Supabase (app crashes without these three)
# https://app.supabase.com → Project → Settings → API
# ============================================================

# Project URL — must start with https://
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — server-only, DO NOT prefix with NEXT_PUBLIC_
# Has full database access. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ============================================================
# OPTIONAL — Admin Access
# Comma-separated list of email addresses with admin access.
# ============================================================

ADMIN_EMAILS=your@email.com


# ============================================================
# OPTIONAL — AI Report Generation
# Falls back to template report if no AI key is set.
# Primary (OpenAI) is tried first; Anthropic is the fallback.
# ============================================================

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...


# ============================================================
# OPTIONAL — GitHub Monitoring
# Returns {configured: false} if GITHUB_TOKEN is absent.
# Scope required: repo (read-only)
# https://github.com/settings/tokens
# ============================================================

GITHUB_TOKEN=ghp_...


# ============================================================
# OPTIONAL — Vercel Monitoring
# Returns empty data if VERCEL_TOKEN is absent.
# https://vercel.com/account/tokens
# ============================================================

VERCEL_TOKEN=...
# Required only for team accounts
VERCEL_TEAM_ID=team_...


# ============================================================
# OPTIONAL — Email Alerts (Resend)
# Returns early without sending if RESEND_API_KEY is absent.
# https://resend.com/api-keys
# ============================================================

RESEND_API_KEY=re_...
ALERT_EMAIL_TO=your@email.com
# Defaults to alerts@masterops.ai if unset
ALERT_EMAIL_FROM=alerts@masterops.ai


# ============================================================
# OPTIONAL — Telegram Alerts
# Returns early without sending if TELEGRAM_BOT_TOKEN is absent.
# ============================================================

TELEGRAM_BOT_TOKEN=1234567890:ABCDef...
TELEGRAM_CHAT_ID=-100123456789


# ============================================================
# OPTIONAL — Cron & Ingest Authentication
# If CRON_SECRET is unset, cron endpoints allow all callers.
# If ingest secrets are unset, ingest endpoints are open.
# ============================================================

# Shared secret passed as ?secret= query param to cron routes
CRON_SECRET=generate-a-random-string-here

# Auth token for POST /api/security/log-event (x-masterops-secret header)
SECURITY_INGEST_SECRET=generate-a-random-string-here

# Auth token for POST /api/costs/log-usage (x-masterops-secret header)
USAGE_INGEST_SECRET=generate-a-random-string-here


# ============================================================
# OPTIONAL — Cost Monitoring
# Creates an emergency alert if today's spend exceeds this.
# Defaults to £10/day if unset.
# ============================================================

DAILY_COST_LIMIT_GBP=10


# ============================================================
# OPTIONAL — Supabase Management API
# Used for infrastructure monitoring, not the database client.
# https://app.supabase.com/account/tokens
# ============================================================

# from supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=sbp_...
# from your Supabase org settings URL
SUPABASE_ORG_ID=org_...


# ============================================================
# OPTIONAL — Rate Limiting (Upstash Redis)
# Fails open (allows all requests) if these are absent.
# Requires @upstash/ratelimit and @upstash/redis packages.
# https://console.upstash.com → Redis → REST API
# ============================================================

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
